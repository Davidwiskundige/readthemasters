# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/

# Node / Astro
node_modules/
site/dist/
site/.astro/
.env

# Generated by `npm run data` (pipeline/build_site_data.py)
site/src/data/works.json
# Compiled at deploy time by pipeline/build_pdfs.py (never committed)
site/public/pdf/
# Source .tex copies emitted by build_site_data.py (never committed)
site/public/tex/
# Figure crops copied into the site by build_site_data.py (source lives in corpus/<id>/figures/)
site/public/figures/

# Build artifacts
*.pdf
!corpus/**/figures/*.pdf
# Optional pre-made PDF overrides (see build_pdfs.py) are committed
!corpus/**/pdf/*.pdf
catalog.json
dist/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local Claude Code settings (launch.json is shared, settings.local.json is per-user)
.claude/settings.local.json
