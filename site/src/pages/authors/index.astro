---
import Base from "../../layouts/Base.astro";
import data from "../../data/works.json";

const authors = data.authors ?? [];
const life = (a) => (a.birth_year || a.death_year)
  ? `${a.birth_year ?? "?"} – ${a.death_year ?? "?"}` : null;
---
<Base title="Authors" description="Authors of the public-domain works transcribed and translated on ReadTheMasters.">
  <h1>Authors</h1>
  <p class="attr">{authors.length} author{authors.length === 1 ? "" : "s"} in the corpus.</p>
  <ul class="authorlist">
    {authors.map((a) => (
      <li class="card">
        <h3><a href={a.url}>{a.name}</a></h3>
        <div class="meta">
          {life(a) && <span>{life(a)}</span>}
          {a.bio && <span>· {a.bio}</span>}
          <span class="pill">{a.work_count} work{a.work_count === 1 ? "" : "s"}</span>
        </div>
      </li>
    ))}
  </ul>
</Base>
