---
import Base from "../../layouts/Base.astro";
import data from "../../data/works.json";

export function getStaticPaths() {
  return (data.authors ?? []).map((a) => ({ params: { slug: a.slug }, props: { author: a } }));
}

const { author } = Astro.props;

// Life dates line: "1682 – 1766". A missing year shows as "?".
const life = (author.birth_year || author.death_year)
  ? `${author.birth_year ?? "?"} – ${author.death_year ?? "?"}` : null;

const description = [author.name, life, author.bio].filter(Boolean).join(" · ");
---
<Base title={author.name} description={description}>
  <div class="authorhead">
    {author.portrait?.url && (
      <figure class="portrait">
        {author.portrait.source
          ? <a href={author.portrait.source} rel="noopener" title="Source: Wikimedia Commons">
              <img src={author.portrait.url}
                   alt={author.portrait.alt ?? `Portrait of ${author.name}`} loading="lazy" />
            </a>
          : <img src={author.portrait.url}
                 alt={author.portrait.alt ?? `Portrait of ${author.name}`} loading="lazy" />}
        {author.portrait.credit && <figcaption class="attr">{author.portrait.credit}</figcaption>}
      </figure>
    )}
    <div class="authormeta">
      <h1>{author.name}</h1>
      {author.bio && <p class="sub">{author.bio}</p>}
      {life && <p class="sub dates">{life}</p>}
      {author.mactutor_url && (
        <p class="links">
          <a href={author.mactutor_url} rel="noopener">Biography (MacTutor)</a>
        </p>
      )}
    </div>
  </div>

  <section>
    <h2 class="worksh">Works on this site ({author.work_count})</h2>
    <ul class="works">
      {author.works.map((w) => (
        <li class="card">
          <h3><a href={w.url}>{w.title}</a></h3>
          {w.title_en && <div class="meta"><em>{w.title_en}</em></div>}
          <div class="meta">
            <span>{w.year}</span>
            {w.venue_full && <span class="pill">{w.venue_full}</span>}
            <span class={`badge ${w.status}`}>{w.status}</span>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <p style="margin-top:1.5rem"><a href="/authors/">← All authors</a></p>
</Base>
