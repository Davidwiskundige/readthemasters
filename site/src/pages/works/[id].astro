---
import Base from "../../layouts/Base.astro";
import data from "../../data/works.json";
import { texToHtml } from "../../lib/tex.js";
import { bibtexEntries } from "../../lib/bibtex.js";

export function getStaticPaths() {
  return (data.works ?? []).map((w) => ({ params: { id: w.id }, props: { work: w } }));
}

const { work } = Astro.props;
const authors = work.authors.map((a) => a.name).join(", ");
const tp = work.transcription_provenance ?? {};

function attribution(prov) {
  if (!prov) return "";
  const parts = [];
  if (prov.model) parts.push(prov.model);
  if (prov.effort) parts.push(`effort: ${prov.effort}`);
  const who = (prov.reviewers ?? []).map((r) => r.name).join(", ");
  let s = `Produced by ${parts.join(", ")}`;
  if (prov.produced) s += ` (${prov.produced})`;
  if (who) s += ` · reviewed by ${who}`;
  return s;
}

// Significance prose with inline [n] citation markers. Each renders as a small superscript
// marker whose full citation is hidden until you hover or click it (a popover).
function renderSignificance(text, sources) {
  const esc = (s) => String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  return esc(text).replace(/\[(\d+)\]/g, (m, n) => {
    const src = sources?.[Number(n) - 1];
    if (!src) return m;
    const cite = esc(src.citation);
    const inner = src.url ? `<a href="${esc(src.url)}" rel="noopener">${cite}</a>` : cite;
    return `<span class="pop cite"><button type="button" class="pop-marker" aria-label="Citation ${n}">${n}</button>` +
           `<span class="pop-content" role="note">${inner}</span></span>`;
  });
}

const figOpts = { figureBase: `/figures/${work.id}/` };
const originalHtml = texToHtml(work.original_tex, figOpts);
const translations = Object.entries(work.translations ?? {}).map(([lang, t]) => ({
  lang, label: t.label, html: texToHtml(t.tex, figOpts), prov: t.provenance, pdf: t.pdf, tex_url: t.tex_url,
}));
const externalTranslations = work.external_translations ?? [];

// Ready-made BibTeX for the original, our edition, and translations, indexed by kind so each
// entry can sit next to its own source/download row rather than in a block at the bottom.
const citations = bibtexEntries(work, { base: Astro.site?.origin ?? "" });
const citeOriginal = citations.find((c) => c.kind === "original");
const citeTranscription = citations.find((c) => c.kind === "transcription");
const citeByLang = Object.fromEntries(
  citations.filter((c) => c.kind === "translation").map((c) => [c.lang, c]));
const citeExternal = citations.filter((c) => c.kind === "external");

// One consolidated download list, each row carrying its own citation.
const downloads = [
  { label: `Original (${work.language_label})`, tex: work.original_tex_url,
    pdf: work.original_pdf, cite: citeTranscription },
  ...translations.map((t) => ({ label: `${t.label} translation`, tex: t.tex_url,
    pdf: t.pdf, cite: citeByLang[t.lang] })),
];

// Prefilled "report an error" issue link (PLAN.md backlog #2).
const repo = "https://github.com/OWNER/readthemasters"; // TODO: set real repo
const reportUrl = `${repo}/issues/new?title=${encodeURIComponent(`Error in ${work.id}`)}&body=${encodeURIComponent(`Work: ${work.id}\nWhere (page/paragraph):\nProblem:\n`)}`;
---
<Base title={work.title} description={work.title_en ?? work.title}>
  <div class="workhead">
    <h1>{work.title}</h1>
    {work.title_en && <p class="sub"><em>{work.title_en}</em></p>}
    <p class="sub">
      {authors} · {work.year}
      {work.venue_label && <> · {work.venue_label}</>}
      · <span class={`badge ${work.status}`}>{work.status}</span>
    </p>
  </div>

  <p>
    <strong>Source:</strong>
    <a href={work.source.scan_url} rel="noopener">original scan</a>
    {work.source.scan_id && <> ({work.source.scan_id})</>}
    {citeOriginal && <> <button class="chip copy" type="button" data-target={`bib-${citeOriginal.key}`}><span class="g">⧉</span> BibTeX</button></>}
    {work.publication_full && <><br /><span class="attr">{work.publication_full}</span></>}
  </p>

  {work.significance && (
    <aside class="significance">
      <h2>Significance</h2>
      <p set:html={renderSignificance(work.significance, work.significance_sources)} />
    </aside>
  )}

  <section class="downloads">
    <h2>Downloads</h2>
    <ul>
      {downloads.map((d) => (
        <li>
          <span>{d.label}:</span>
          {d.tex && <a class="chip" href={d.tex} download rel="noopener"><span class="g">↓</span> .tex</a>}
          {d.pdf
            ? <a class="chip" href={d.pdf} download rel="noopener"><span class="g">↓</span> PDF</a>
            : <span class="attr note">PDF on deploy</span>}
          {d.cite && <button class="chip copy" type="button" data-target={`bib-${d.cite.key}`}><span class="g">⧉</span> BibTeX</button>}
        </li>
      ))}
      <li>
        <span class="attr">Shared preamble:</span>
        <a class="chip" href="/tex/readmasters.sty" download rel="noopener"><span class="g">↓</span> readmasters.sty</a>
        <span class="attr">(needed to compile a <code>.tex</code>)</span>
      </li>
      <li>
        <span class="attr">All citations:</span>
        <button id="dl-bib" class="chip" type="button" data-file={`${work.id}.bib`}><span class="g">↓</span> .bib</button>
      </li>
    </ul>
  </section>

  {work.status === "ai-draft" && (
    <div class="notice">
      This text is an <strong>AI draft</strong> and has not yet been human-checked.
      Spotted a mistake? <a href={reportUrl} rel="noopener">Report an error</a>.
    </div>
  )}

  <div class="tabs" role="tablist">
    <button role="tab" aria-selected="true" data-tab="original">Original ({work.language_label})</button>
    {translations.map((t) => (
      <button role="tab" aria-selected="false" data-tab={t.lang}>Translation ({t.label})</button>
    ))}
  </div>

  <section class="text" data-panel="original">
    <p class="attr">{attribution(tp)}</p>
    <div set:html={originalHtml} />
  </section>
  {translations.map((t) => (
    <section class="text" data-panel={t.lang} hidden>
      <p class="attr">{attribution(t.prov)}</p>
      <div set:html={t.html} />
    </section>
  ))}

  {externalTranslations.length > 0 && (
    <section style="margin-top:2rem">
      <h2 style="font-size:1.1rem">Existing translations elsewhere</h2>
      <p class="attr">These are hosted by others; we link rather than duplicate them.</p>
      <ul>
        {externalTranslations.map((x, i) => (
          <li>
            <a href={x.url} rel="noopener">{x.title ?? `${x.language?.toUpperCase()} translation`}</a>
            {x.translator && <> — trans. {x.translator}</>}
            {x.year && <> ({x.year})</>}
            {x.venue && <>, {x.venue}</>}
            {x.license && <> · <span class="pill">{x.license}</span></>}
            {citeExternal[i] && <> · <button class="chip copy" type="button" data-target={`bib-${citeExternal[i].key}`}><span class="g">⧉</span> BibTeX</button></>}
            {x.note && <><br /><span class="attr">{x.note}</span></>}
          </li>
        ))}
      </ul>
    </section>
  )}

  <p style="margin-top:2rem"><a href={reportUrl} rel="noopener">Report an error in this text →</a></p>

  {/* Hidden BibTeX source for the inline "copy BibTeX" buttons and the .bib download. */}
  <div id="bib-store" hidden>
    {citations.map((c) => <pre id={`bib-${c.key}`}>{c.text}</pre>)}
  </div>

  <!-- KaTeX renders any inline math ($…$, \[…\]) present in the text. -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
  <script>
    document.querySelectorAll('.tabs button').forEach((btn) => {
      btn.addEventListener('click', () => {
        const tab = btn.dataset.tab;
        document.querySelectorAll('.tabs button').forEach((b) =>
          b.setAttribute('aria-selected', String(b === btn)));
        document.querySelectorAll('[data-panel]').forEach((p) =>
          (p.hidden = p.dataset.panel !== tab));
      });
    });

    // Popover markers: hover shows them (CSS); click pins one open (touch-friendly). Shared by
    // significance citation markers and in-text editorial notes (\ednote) — anything with a
    // ".pop" wrapper. JS positions each popover so it always stays within the viewport.
    const allPops = () => document.querySelectorAll('.pop');
    function positionPop(wrap) {
      const pop = wrap.querySelector('.pop-content');
      if (!pop) return;
      pop.style.position = 'fixed';
      const pw = pop.offsetWidth, ph = pop.offsetHeight, m = 8;
      const r = (wrap.querySelector('.pop-marker') || wrap).getBoundingClientRect();
      let left = Math.min(Math.max(m, r.left), window.innerWidth - pw - m);
      left = Math.max(m, left);
      let top = r.bottom + 4;
      if (top + ph > window.innerHeight - m) top = Math.max(m, r.top - ph - 4);
      pop.style.left = left + "px";
      pop.style.top = top + "px";
    }
    const closeAllPops = () =>
      document.querySelectorAll('.pop.open').forEach((c) => c.classList.remove('open'));
    allPops().forEach((wrap) => {
      const marker = wrap.querySelector('.pop-marker');
      wrap.addEventListener('mouseenter', () => positionPop(wrap));
      marker.addEventListener('focus', () => positionPop(wrap));
      marker.addEventListener('click', (e) => {
        e.stopPropagation();
        const wasOpen = wrap.classList.contains('open');
        closeAllPops();
        if (!wasOpen) { wrap.classList.add('open'); positionPop(wrap); }
      });
    });
    document.addEventListener('click', closeAllPops);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAllPops(); });
    const repositionVisiblePops = () => allPops().forEach((wrap) => {
      const pop = wrap.querySelector('.pop-content');
      if (pop && getComputedStyle(pop).display !== 'none') positionPop(wrap);
    });
    window.addEventListener('scroll', repositionVisiblePops, { passive: true });
    window.addEventListener('resize', repositionVisiblePops);

    // Copy text to clipboard, with a fallback for non-secure/no-gesture contexts.
    async function copyText(text) {
      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(text);
          return true;
        }
      } catch (_) { /* fall through */ }
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      let ok = false;
      try { ok = document.execCommand('copy'); } catch (_) { ok = false; }
      document.body.removeChild(ta);
      return ok;
    }

    // Copy a single BibTeX entry (buttons live inline next to source/download rows).
    document.querySelectorAll('button.copy[data-target]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const pre = document.getElementById(btn.dataset.target);
        if (!pre) return;
        const ok = await copyText(pre.textContent);
        const prev = btn.textContent;
        btn.textContent = ok ? 'copied ✓' : 'press Ctrl+C';
        setTimeout(() => (btn.textContent = prev), 1500);
      });
    });

    // Download all entries as one .bib file.
    const dl = document.getElementById('dl-bib');
    if (dl) dl.addEventListener('click', () => {
      const all = [...document.querySelectorAll('#bib-store pre')].map((p) => p.textContent).join('\n\n');
      const blob = new Blob([all], { type: 'application/x-bibtex' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = dl.dataset.file;
      a.click();
      URL.revokeObjectURL(a.href);
    });
  </script>
  <script type="module">
    import renderMathInElement from "https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.mjs";
    document.querySelectorAll('.text').forEach((el) =>
      renderMathInElement(el, {
        delimiters: [
          { left: "$$", right: "$$", display: true },
          { left: "\\[", right: "\\]", display: true },
          { left: "$", right: "$", display: false },
        ],
        throwOnError: false,
      }));
  </script>
</Base>
