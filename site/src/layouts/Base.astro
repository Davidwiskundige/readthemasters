---
import "../styles/global.css";
const { title, description } = Astro.props;
const siteTitle = "ReadTheMasters";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} · ${siteTitle}` : siteTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="/logo.svg" type="image/svg+xml" />
  </head>
  <body>
    <header class="site">
      <nav>
        <a class="brand" href="/">
          <svg class="brandmark" viewBox="0 0 32 32" width="24" height="24" aria-hidden="true" focusable="false">
            <g fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 11.5 L16 25.5"/>
              <path d="M16 11.5 C12 9.5 7.5 10 4.5 12.5 L4.5 24 C7.5 21.5 12 22 16 24"/>
              <path d="M16 11.5 C20 9.5 24.5 10 27.5 12.5 L27.5 24 C24.5 21.5 20 22 16 24"/>
              <path d="M16 17 C14.4 14.8 10.8 14.8 10.8 17 C10.8 19.2 14.4 19.2 16 17 C17.6 14.8 21.2 14.8 21.2 17 C21.2 19.2 17.6 19.2 16 17 Z" stroke-width="1.5"/>
            </g>
          </svg>
          ReadTheMasters
        </a>
        <a href="/">Catalog</a>
        <a href="/about/">About</a>
        <a href="/copyright/">Copyright</a>
        <a href="/contribute/">Contribute</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site">
      <p>
        Transcriptions, translations and metadata are dedicated to the public domain (CC0).
        Original texts are public domain worldwide. This is a good-faith project and not legal
        advice — see <a href="/copyright/">Copyright &amp; takedown</a>.
      </p>
    </footer>
  </body>
</html>
