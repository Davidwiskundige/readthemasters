---
import "../styles/global.css";
const { title, description } = Astro.props;
const siteTitle = "ReadTheMasters";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} · ${siteTitle}` : siteTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="/logo.svg" type="image/svg+xml" />
  </head>
  <body>
    <header class="site">
      <nav>
        <a class="brand" href="/">
          <span class="wordmark">ReadTheMasters</span>
          <span class="rule"><span class="diamond">◆</span></span>
          <span class="tagline">Transcribe · Translate · Revive</span>
        </a>
        <div class="navlinks">
          <a href="/">Catalog</a>
          <a href="/search/">Search</a>
          <a href="/about/">About</a>
          <a href="/copyright/">Copyright</a>
          <a href="/contribute/">Contribute</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site">
      <p>
        Transcriptions, translations and metadata are dedicated to the public domain (CC0).
        Original texts are public domain worldwide. This is a good-faith project and not legal
        advice — see <a href="/copyright/">Copyright &amp; takedown</a>.
      </p>
    </footer>
  </body>
</html>
